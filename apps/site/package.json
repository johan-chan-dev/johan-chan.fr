    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "pagefind": "^1.3.0",
    "sharp": "^0.34.3",
    "svelte-check": "^4.3.5",
    "tailwindcss": "4.3.0",
