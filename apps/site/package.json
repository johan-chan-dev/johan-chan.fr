{
  "name": "@johan-chan/site",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "check": "astro check && svelte-check && vue-tsc --noEmit -p tsconfig.vue.json && tsc -p tsconfig.demos.json",
    "test:unit": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@analogjs/astro-angular": "^2.6.0",
    "@angular/animations": "^21",
    "@angular/build": "^21",
    "@angular/common": "^21",
    "@angular/compiler": "^21",
    "@angular/compiler-cli": "^21",
    "@angular/core": "^21",
    "@angular/platform-browser": "^21",
    "@angular/platform-server": "^21",
    "@astrojs/mdx": "6.0.1",
    "@astrojs/react": "^5.0.7",
    "@astrojs/svelte": "^8.1.2",
    "@astrojs/vue": "^6.0.1",
    "astro": "6.4.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rxjs": "^7.8.2",
    "svelte": "5.48.0",
    "tslib": "^2.8.1",
    "vue": "^3.5.35",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@playwright/test": "1.60.0",
    "@tailwindcss/vite": "4.3.0",
