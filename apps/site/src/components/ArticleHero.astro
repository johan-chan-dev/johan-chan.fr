---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { Lang } from '../i18n/ui';
import { copy, fmtDate, type Registre } from '../lib/copy';

interface Props {
  image: ImageMetadata;
  imageFocus?: 'center' | 'top' | 'bottom';
  title: string;
  excerpt?: string;
  date: string;
  readingTime: number;
  tags: string[];
  registre: Registre;
  series?: { id: string; title: string };
  order?: number;
  lang: Lang;
}
const { image, imageFocus = 'center', title, excerpt, date, readingTime, tags, registre, series, order, lang } = Astro.props;
const C = copy[lang];
const seriesHref = series ? `${lang === 'fr' ? '' : '/en'}/series/${series.id}` : null;
---
<figure
  class="relative -mx-[22px] mb-10 flex min-h-[480px] flex-col justify-end overflow-hidden rounded-[16px] md:-mx-[56px]"
>
  <Image src={image} alt={title} widths={[640, 960, 1280, 1600]} sizes="(min-width: 1136px) 1080px, 100vw"
    class="absolute inset-0 h-full w-full object-cover" style={`object-position: ${imageFocus}`} />
  <div class="absolute inset-0"
    style="background: linear-gradient(to bottom, transparent 0%, transparent 28%, rgba(0,0,0,.5) 62%, rgba(0,0,0,.86) 100%)"></div>

  <div class="relative z-10 mx-auto w-full max-w-[680px] px-[22px] pb-9 pt-12 md:px-0"
    style="color:#ededed;text-shadow:0 1px 6px rgba(0,0,0,.5)">
    <div class="atl-meta mb-3 uppercase" style="font-size:11px;letter-spacing:.12em;color:rgba(255,255,255,.82)">
      {series ? (
        <a href={seriesHref} style="color:inherit">{C.series} · {series.title}, {C.chapter} {order}</a>
      ) : (
        <span>{C.kind[registre]}</span>
      )}
    </div>
    <h1 class="font-display text-[31px] font-bold leading-[1.05] tracking-[-.03em] md:text-[46px]" style="text-wrap:balance">{title}</h1>
    {excerpt && (
      <p class="mt-4 max-w-[600px] font-text text-[16px] leading-[1.5] md:text-[18px]" style="color:rgba(255,255,255,.9)">{excerpt}</p>
    )}
    <div class="atl-meta mt-5 flex flex-wrap items-center gap-3" style="font-size:11.5px;color:rgba(255,255,255,.72)">
      <span>{fmtDate(date, lang)}</span><span>·</span><span>{readingTime} {C.read}</span>
      {tags.length > 0 && <span>·</span>}
      <span class="flex flex-wrap gap-2">{tags.map((tg) => <span>#{tg.toLowerCase()}</span>)}</span>
    </div>
  </div>
</figure>
