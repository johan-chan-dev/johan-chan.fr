---
interface Props { title?: string; type?: 'note' | 'tip' | 'warning'; class?: string }
const { title, type = 'note', class: className } = Astro.props;
---
<aside
  class:list={["atl-callout my-7 rounded-[12px] border border-line border-l-[3px] border-l-accent bg-surf px-4 py-3.5", className]}
  data-testid="callout"
  data-type={type}
>
  {title && (
    <p class="atl-meta mb-1.5 font-semibold uppercase tracking-[.04em] text-accent" style="font-size:12px">{title}</p>
  )}
  <div class="atl-body m-0 text-ink2" style="line-height:1.65"><slot /></div>
</aside>
