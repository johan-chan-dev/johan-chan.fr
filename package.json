{
	"name": "johan-chan-monorepo",
	"private": true,
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"check": "turbo run check",
		"lint": "turbo run lint",
		"test": "turbo run test",
		"test:unit": "turbo run test:unit",
		"test:e2e": "turbo run test:e2e",
		"dev:web": "pnpm --filter @johan-chan/web dev",
		"build:web": "pnpm --filter @johan-chan/web build",
		"check:web": "pnpm --filter @johan-chan/web check",
		"format": "pnpm --filter @johan-chan/web format"
	},
	"devDependencies": {
		"@dotenv-run/cli": "^1.3.6",
		"tsx": "^4.21.0",
		"turbo": "^2.7.5"
	},
	"packageManager": "pnpm@9.15.0",
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
